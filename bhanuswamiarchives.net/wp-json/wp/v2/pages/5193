le":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/users\/3"}],"replies":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/comments?post=5193"}],"version-history":[{"count":2,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/5193\/revisions"}],"predecessor-version":[{"id":5195,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/5193\/revisions\/5195"}],"wp:attachment":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/media?parent=5193"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}