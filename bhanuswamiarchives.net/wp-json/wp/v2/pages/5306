sh","hentry"],"_links":{"self":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/5306","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/users\/3"}],"replies":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/comments?post=5306"}],"version-history":[{"count":1,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/5306\/revisions"}],"predecessor-version":[{"id":5307,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/5306\/revisions\/5307"}],"wp:attachment":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/media?parent=5306"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}