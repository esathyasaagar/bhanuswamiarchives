et\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/users\/3"}],"replies":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/comments?post=3928"}],"version-history":[{"count":1,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/3928\/revisions"}],"predecessor-version":[{"id":3929,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/3928\/revisions\/3929"}],"wp:attachment":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/media?parent=3928"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}