e63\u1e47i-v\u012br\u0101&nbsp;bh\u1e5b\u015b\u0101rdit\u0101\u1e25&nbsp; na&nbsp;tatyaj\u016b&nbsp;ra\u1e47a\u1e41&nbsp;sva\u1e41&nbsp;sva\u1e41&nbsp; loka-dvaya-jig\u012b\u1e63ava\u1e25&nbsp; Synonyms&nbsp; [&hellip;]<\/p>\n","protected":false},"author":3,"featured_media":0,"parent":0,"menu_order":0,"comment_status":"open","ping_status":"open","template":"","meta":{"footnotes":""},"class_list":["post-3769","page","type-page","status-publish","hentry"],"_links":{"self":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/3769","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/users\/3"}],"replies":[{"embeddable":true,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/comments?post=3769"}],"version-history":[{"count":1,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/3769\/revisions"}],"predecessor-version":[{"id":3770,"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/pages\/3769\/revisions\/3770"}],"wp:attachment":[{"href":"https:\/\/bhanuswamiarchives.net\/wp-json\/wp\/v2\/media?parent=3769"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}